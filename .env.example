# =============================================================================
# Budget Tracker — Environment Variables
# =============================================================================
# Copy this file to `.env.local` (for Next.js local dev) and / or `.env`
# (for docker-compose). Never commit filled-in values.
# =============================================================================

# --- Application -------------------------------------------------------------
NODE_ENV=development
APP_NAME="Budget Tracker"
APP_URL=http://localhost:3000
TZ=America/New_York

# --- Database ----------------------------------------------------------------
# Local dev via docker-compose.dev.yml:
DATABASE_URL=postgresql://budget:budget@localhost:5432/budget_tracker
DATABASE_SSL=false
# Production (VPS): use the compose-internal hostname, e.g.
# DATABASE_URL=postgresql://budget:REDACTED@postgres:5432/budget_tracker

# --- Better Auth -------------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-a-32-byte-random-value
BETTER_AUTH_URL=http://localhost:3000

# --- Anthropic (AI features) -------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL_CHAT=claude-opus-4-6
ANTHROPIC_MODEL_BATCH=claude-haiku-4-5-20251001
# Hard monthly spend cap per family (USD). Defaults to $10 if unset.
AI_MONTHLY_SPEND_CAP_USD=10

# --- Encryption --------------------------------------------------------------
# Master key used to encrypt SimpleFIN access URLs at rest. 32 bytes base64.
# Generate with: openssl rand -base64 32
ENCRYPTION_MASTER_KEY=replace-me-with-a-32-byte-random-value

# --- SimpleFIN ---------------------------------------------------------------
# There are no global SimpleFIN env vars — per-connection Access URLs are
# stored encrypted in the `connection` table. Users paste a Setup Token via
# the app UI during onboarding.

# --- Email (Phase 3+) --------------------------------------------------------
# Optional. If unset, insights are shown in-app only (no email delivery).
RESEND_API_KEY=
EMAIL_FROM="Budget Tracker <noreply@example.com>"

# --- Backups (Phase 0b deploy) -----------------------------------------------
# Off-site nightly pg_dump → Backblaze B2. Encrypted with `age` using the
# ENCRYPTION_MASTER_KEY above. Leave blank to skip off-site backups for v1.
BACKUP_B2_KEY_ID=
BACKUP_B2_APPLICATION_KEY=
BACKUP_B2_BUCKET=
BACKUP_RETENTION_DAYS=30

# --- Monitoring --------------------------------------------------------------
# Optional Healthchecks.io ping URLs for cron jobs; UptimeRobot for public HTTP.
HEALTHCHECKS_SYNC_PING_URL=
HEALTHCHECKS_INSIGHTS_PING_URL=

# --- Rate limits / quotas ----------------------------------------------------
# SimpleFIN upstream enforces 24 /accounts requests per day. We stay well under.
SIMPLEFIN_PULLS_PER_DAY=1
SIMPLEFIN_TRAILING_WINDOW_DAYS=7
