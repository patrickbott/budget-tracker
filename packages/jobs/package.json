{
  "name": "@budget-tracker/jobs",
  "version": "0.0.0",
  "private": true,
  "description": "pg-boss job workers for Budget Tracker: SimpleFIN sync, auto-categorization, insights generation.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./boss": {
      "types": "./src/boss.ts",
      "import": "./src/boss.ts"
    }
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:integration:watch": "vitest -c vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@budget-tracker/ai": "workspace:*",
    "@budget-tracker/core": "workspace:*",
    "@budget-tracker/db": "workspace:*",
    "@budget-tracker/simplefin": "workspace:*",
    "decimal.js": "^10.4.3",
    "drizzle-orm": "^0.45.2",
    "pg-boss": "^10.1.5",
    "postgres": "^3.4.9",
    "resend": "^4.5.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
